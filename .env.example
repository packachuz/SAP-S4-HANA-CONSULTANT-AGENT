# Optional — enables the MD planner & synthesizer to use Gemini.
# Without this the orchestrator uses a deterministic heuristic fallback.
GOOGLE_API_KEY=

# Optional — override the location of the NotebookLM browser-storage file.
# Defaults to ~/.notebooklm/storage.json
# NOTEBOOKLM_STORAGE=/absolute/path/to/storage.json

# Optional — set on Cloud Run so a failed NotebookLM connect surfaces as an
# error instead of silently degrading to STUB mode.
# NOTEBOOKLM_REQUIRE_LIVE=1

# Optional — GCS bucket for durable RAG state (notebook registry + podcasts).
# Without it, state lives on the ephemeral container disk and is lost on restart.
# GCS_STATE_BUCKET=your-bucket-name
